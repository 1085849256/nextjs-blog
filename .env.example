# ===========================================
# Next.js 全栈博客系统 - 环境变量配置
# 复制此文件为 .env.local 并填入实际值
# ===========================================

# 数据库配置
# 本地开发:
#   DATABASE_URL="file:./dev.db"
#   DATABASE_PROVIDER="sqlite"
# 生产环境(Neon/Vercel Postgres):
#   DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
#   DATABASE_PROVIDER="postgresql"
DATABASE_URL="file:./dev.db"
DATABASE_PROVIDER="sqlite"

# NextAuth.js 认证配置
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-secret-min-32-chars"

# 管理员账户（首次运行自动创建）
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-password"
ADMIN_NAME="管理员"

# 站点信息配置
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="我的技术博客"
NEXT_PUBLIC_SITE_DESCRIPTION="分享技术与生活，记录成长历程"
NEXT_PUBLIC_SITE_AUTHOR="博主"
